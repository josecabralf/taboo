#!/bin/bash
# setup-project runs after the project is mounted at /project (setup-base has
# already installed python3-venv). It provisions the Material for MkDocs
# toolchain that `make docs-serve` needs, installed from the project's own
# requirements.txt so the version pins stay in exactly one place.
set -euo pipefail

# The Material for MkDocs toolchain is a dev-workshop convenience for
# `make docs-serve`. taboo's own agent workshop derives from this same SDK but
# mounts .taboo (not the repo root) as /project, so it has no requirements.txt,
# and the agent never serves docs. Skip provisioning when there is nothing to
# install rather than aborting the launch.
if [ ! -f /project/requirements.txt ]; then
  echo "setup-project: no /project/requirements.txt; skipping docs toolchain"
  exit 0
fi

# Keep the venv outside /project so it never collides with a host-side install.
DOCS_VENV="$HOME/.docs-venv"
python3 -m venv "$DOCS_VENV"
"$DOCS_VENV/bin/pip" install -r /project/requirements.txt

# Expose `mkdocs` on PATH for both `workshop run -- make docs-serve` (a
# non-login shell that only sees /usr/local/bin) and interactive `workshop
# shell` sessions. The symlinked entrypoint keeps its venv shebang, so it
# resolves mkdocs-material from the venv.
sudo ln -sf "$DOCS_VENV/bin/mkdocs" /usr/local/bin/mkdocs
