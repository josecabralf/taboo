# .env.example — generated by `taboo init` for agent claude-code.
# Copy this to .env, fill in the credential(s) you hold, then load them into
# your shell (e.g. `set -a; source .env; set +a`) before running taboo.
# taboo forwards only the keys present in the environment when it runs,
# so you only need to provide the one credential you use. Subscription users
# set CLAUDE_CODE_OAUTH_TOKEN (from `claude setup-token`); API users set
# ANTHROPIC_API_KEY instead.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
